pipeline {
    agent any

    stages {
        stage('Unit Tests - Backend') {
             agent {
                docker {
                    image 'golang:1.21'
                    reuseNode true
                }
            }
             environment {
                GOCACHE = "${WORKSPACE}/.gocache"
            }
            steps {
               dir('bugtracker-backend') {
                sh '''
                    mkdir -p $GOCACHE
                    go version
                    go test -v ./...
                    '''
               }
            }
        }
        stage('Unit Tests - Frontend') {
            agent {
                docker {
                    image 'node:20-alpine'
                    reuseNode true
                }
            }
            steps {
               dir('bugtracker-frontend') {
                sh '''
                    node --version
                    npm ci
                    npm test
                    '''
               }
            }
        }
    }
}
